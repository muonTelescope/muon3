  (text "Shield is AC-grounded through C1 at the connector -> shields normally; bias+signal share one coax, minimal loop area." (at 20 40 0) (effects (font (size 1.6 1.6)) (justify left)) (uuid 0b50095e-1580-4586-9f02-188da11554cc))
