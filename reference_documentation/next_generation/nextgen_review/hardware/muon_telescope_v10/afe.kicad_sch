  (text "Per channel: DC-coupled anode readout. OPA858 TIA Rf=2k Cf=2.2p -> 24.4mV/p.e., 52MHz." (at 20 25 0) (effects (font (size 1.6 1.6)) (justify left)) (uuid "c422399d-d9c3-42ac-affe-e1f8dccbbfd4"))
