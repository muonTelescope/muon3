(kicad_sch (version 20250114) (generator "eeschema") (generator_version "9.0")
  (uuid "10000000-0000-4000-8000-000000000040") (paper "A3")
  (title_block (title "Muon3 Peltier and temperature control") (date "2026-07-11") (rev "P0") (comment 1 "ARCHITECTURE - electrical capture pending"))
  (lib_symbols)
  (text "Repeat x4: protected bus (from TPS25751/BQ path) -> DRV8873HPWPR -> polarized panel Peltier + fan" (at 25 35 0) (effects (font (size 2 2)) (justify left)) (uuid "14000000-0000-4000-8000-000000000001"))
  (text "SPI diagnostics + current regulation. Local fuse, bulk cap, filtered readback per channel." (at 25 48 0) (effects (font (size 1.6 1.6)) (justify left)) (uuid "14000000-0000-4000-8000-000000000002"))
  (text "HARDWARE interlock block (mandatory): window comparators on cold/hot NTCs, hot overtemp, PD contract good, watchdog heartbeat (FPGA preferred), per-channel overcurrent. ALL must be good to enable TEC power. Latching faults preferred." (at 25 62 0) (effects (font (size 1.5 1.5)) (justify left)) (uuid "14000000-0000-4000-8000-000000000003"))
  (text "Firmware (RP2040 + nRF9151) can only REQUEST enable after reading sensors. Hardware always wins and defaults OFF. Tach loss disables associated channel." (at 25 76 0) (effects (font (size 1.5 1.5)) (justify left)) (uuid "14000000-0000-4000-8000-000000000004"))
  (text "Two 8-ch precision DACs provide thresholds + HV trim + spares. BME280 + dew-point still used for condensation guard (firmware advisory)." (at 25 89 0) (effects (font (size 1.5 1.5)) (justify left)) (uuid "14000000-0000-4000-8000-000000000005"))
