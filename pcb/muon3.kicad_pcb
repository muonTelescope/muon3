(kicad_pcb (version 20240108) (generator pcbnew)
  (general (thickness 1.6))
  (paper "A4")
  (layers
    (0 "F.Cu" signal)
    (2 "In1.Cu" power)
    (4 "In2.Cu" power)
    (31 "B.Cu" signal)
    (36 "B.SilkS" user "b.silkscreen")
    (37 "F.SilkS" user "f.silkscreen")
    (44 "Edge.Cuts" user)
    (46 "B.CrtYd" user "b.courtyard")
    (47 "F.CrtYd" user "f.courtyard")
    (48 "B.Fab" user)
    (49 "F.Fab" user)
  )
  (setup
    (pad_to_mask_clearance 0)
    (allow_soldermask_bridges_in_footprints no)
    (tenting front back)
    (pcbplotparams
      (layerselection 0x00010fc_ffffffff)
      (plot_on_all_layers_selection 0x0000000_00000000)
      (disableapertmacros no) (usegerberextensions no) (usegerberattributes yes)
      (usegerberadvancedattributes yes) (creategerberjobfile yes)
      (dashed_line_dash_ratio 12.0) (dashed_line_gap_ratio 3.0)
      (svguseinch no) (svgprecision 4) (excludeedgelayer yes)
      (plotframeref no) (viasonmask no) (mode 1) (useauxorigin no)
      (hpglpennumber 1) (hpglpenspeed 20) (hpglpendiameter 15.0)
      (dxfpolygonmode yes) (dxfimperialunits yes) (dxfusepcbnewfont yes)
      (psnegative no) (psa4output no) (plotreference yes) (plotvalue yes)
      (plotfptext yes) (plotinvisibletext no) (sketchpadsonfab no)
      (subtractmaskfromsilk no) (outputformat 1) (mirror no) (drillshape 1)
      (scaleselection 1) (outputdirectory "fabrication/")))
  (gr_rect (start 20 20) (end 140 110) (stroke (width 0.2) (type default)) (fill none) (layer "Edge.Cuts"))
  (gr_rect (start 23 23) (end 57 54) (stroke (width 0.3) (type dash)) (fill none) (layer "F.SilkS"))
  (gr_text "AFE x4 - quiet/no pour at summing nodes" (at 40 25) (layer "F.SilkS") (effects (font (size 1.1 1.1) (thickness 0.18))))
  (gr_rect (start 60 23) (end 92 54) (stroke (width 0.3) (type dash)) (fill none) (layer "F.SilkS"))
  (gr_text "FPGA + DAC + timing" (at 76 25) (layer "F.SilkS") (effects (font (size 1.1 1.1) (thickness 0.18))))
  (gr_rect (start 95 23) (end 137 54) (stroke (width 0.3) (type dash)) (fill none) (layer "F.SilkS"))
  (gr_text "nRF9151 + SIM + RF keepouts" (at 116 25) (layer "F.SilkS") (effects (font (size 1.1 1.1) (thickness 0.18))))
  (gr_rect (start 23 58) (end 57 107) (stroke (width 0.3) (type dash)) (fill none) (layer "F.SilkS"))
  (gr_text "USB-C PD + rails + HV quarantine" (at 40 60) (layer "F.SilkS") (effects (font (size 1.1 1.1) (thickness 0.18))))
  (gr_rect (start 60 58) (end 137 107) (stroke (width 0.3) (type dash)) (fill none) (layer "F.SilkS"))
  (gr_text "4x Peltier bridges + panel connectors" (at 98.5 60) (layer "F.SilkS") (effects (font (size 1.1 1.1) (thickness 0.18))))
  (gr_text "MUON3 P0 ARCHITECTURE - NOT FOR FABRICATION" (at 80 104) (layer "B.SilkS") (effects (font (size 1.4 1.4) (thickness 0.25)) (justify mirror)))
)
